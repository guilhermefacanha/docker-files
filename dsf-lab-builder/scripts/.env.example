# Copy to .env and edit values to override defaults across ALL scripts
# (rds/* and fam/*). 00-env.sh sources this file with `set -a` so anything
# defined here is exported. Comment a line to fall back to the default.
#
#   cp .env.example .env
#   $EDITOR .env
#
# Override priority (earlier wins):
#   1. inline   :  DB_MASTER_PASS=foo sh rds/service-rds-mysql-dsf-setup.sh
#   2. exported :  export DB_MASTER_PASS=foo  (then run scripts)
#   3. .env     :  values in this file
#   4. defaults :  hard-coded in 00-env.sh / per-script

# ─── AWS / floci endpoint (rds + fam) ─────────────────────────────────────────
#AWS_ENDPOINT_URL=http://localhost:4566
#AWS_ACCESS_KEY_ID=test
#AWS_SECRET_ACCESS_KEY=test
#AWS_DEFAULT_REGION=us-east-1

# ─── docker-compose interpolation (also written by spawn-env.sh) ─────────────
# These drive the host-side ports and account ID floci runs with. Use
# spawn-env.sh to generate non-overlapping values for parallel envs:
#   sh spawn-env.sh                # writes .env.env<next-N>
#   ln -sf .env.env1 .env          # activate env 1 for the rds/fam scripts
#FLOCI_HOST_PORT=4566
#RDS_HOST_PORT_RANGE=7001-7099
#FLOCI_NETWORK=floci-local-aws_default
#FLOCI_DEFAULT_ACCOUNT_ID=000000000000

# ─── DB shared (rds/*) ────────────────────────────────────────────────────────
#DB_MASTER_USER=admin
#DB_MASTER_PASS=secret123
#DB_CLASS=db.t3.micro
#ALLOCATED_STORAGE=20
#LOG_RETENTION_DAYS=90
#AUDIT_MGR_USER=auditmgr
#AUDIT_MGR_PASS=AuditMgr$ecret1

# ─── Engine-specific instance IDs (rds/*) ─────────────────────────────────────
#DB_INSTANCE_ID=mypostgres-dsf       # postgres scripts use mypostgres-dsf
#DB_INSTANCE_ID=mymysql-dsf          # mysql scripts use mymysql-dsf
#DB_INSTANCE_ID=mymariadb-dsf        # mariadb scripts use mymariadb-dsf
# Note: all three engines read the same DB_INSTANCE_ID var, so don't set it
# here if you run more than one engine — set it inline per script instead.

# ─── FAM (fam/*) ──────────────────────────────────────────────────────────────
#FAM_ACCOUNT_ID=000000000000
#FAM_USER_NAME=fam-user
#FAM_SOURCE_BUCKET=fam-lab-source
#FAM_LOG_DESTINATION_BUCKET=fam-lab-logs
#FAM_TRAIL_NAME=fam-cloudtrail
#FAM_ACTOR_COUNT=10
#FAM_PRIVILEGED_COUNT=3
